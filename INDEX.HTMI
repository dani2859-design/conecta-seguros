</section>

<!-- COTIZACIÓN -->
<section class="cotizacion reveal" id="cotizar">
  <div class="wrap">
    <div class="sec-eyebrow">Contacto</div>
    <h2 class="sec-title">Pedí tu<br><em>cotización online.</em></h2>

    <div class="cot-grid">
      <div class="cot-info">
        <div class="cot-info-title">Sin compromiso.<br>Respuesta en menos de 24 horas.</div>
        <p class="cot-info-desc">Completá el formulario o escribinos directamente por WhatsApp. Te enviamos una cotización personalizada con las mejores opciones del mercado.</p>
        <div class="cot-contactos">
          <a href="https://wa.me/5493517315099" target="_blank" class="cot-contacto">
            <div class="cot-contacto-icon">💬</div>
            +54 9 351 731-5099
          </a>
          <a href="mailto:nico.seguros1118@gmail.com" class="cot-contacto">
            <div class="cot-contacto-icon">✉️</div>
            nico.seguros1118@gmail.com
          </a>
          <a href="mailto:nicolas2562@outlook.es" class="cot-contacto">
            <div class="cot-contacto-icon">✉️</div>
            nicolas2562@outlook.es
          </a>
        </div>
      </div>

      <div class="cot-form">
        <div class="cot-form-top"></div>
        <div class="cot-form-inner">
          <div class="cot-form-title">Cotizá online</div>

          <div class="form-group">
            <label class="form-label">Nombre completo *</label>
            <input type="text" class="form-input" id="cot-nombre" placeholder="Tu nombre">
          </div>
          <div class="form-group">
            <label class="form-label">WhatsApp *</label>
            <input type="tel" class="form-input" id="cot-tel" placeholder="11 XXXX-XXXX">
          </div>
          <div class="form-group">
            <label class="form-label">¿Qué seguro necesitás? *</label>
            <select class="form-select" id="cot-tipo">
              <option value="">Elegí una opción</option>
              <option>Automotor — uso particular</option>
              <option>Automotor — uso plataformas (Uber/DiDi/Cabify) · Galicia y Rivadavia</option>
              <option>Cobertura satelital antirrobo</option>
              <option>Accidente personal</option>
              <option>Hogar</option>
              <option>Moto</option>
              <option>Comercio / ART</option>
              <option>Varios seguros</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Mensaje (opcional)</label>
            <input type="text" class="form-input" id="cot-msg" placeholder="Contanos algo más sobre lo que necesitás">
          </div>

          <button class="btn-cotizar" onclick="enviarCotizacion()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L.057 23.886a.5.5 0 00.606.63l6.288-1.634A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.655-.5-5.187-1.375l-.372-.215-3.854 1.002 1.036-3.742-.236-.386A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Enviar por WhatsApp
          </button>
          <p class="cot-nota">Sin compromiso · 100% online · Respondemos en menos de 24hs</p>
        </div>
      </div>
    </div>
  </div>
</section>

