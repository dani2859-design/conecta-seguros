    <div class="porque-grid">
      <div class="porque-items">
        <div class="porque-item">
          <div class="porque-num">01</div>
          <div class="porque-item-content">
            <div class="porque-item-title">Selección estratégica de compañías</div>
            <p class="porque-item-desc">No trabajamos con una sola aseguradora. Comparamos opciones de primer nivel para encontrar la mejor relación precio-cobertura para tu caso.</p>
