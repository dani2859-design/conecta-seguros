<script>
var obs = new IntersectionObserver(function(e){
  e.forEach(function(x){ if(x.isIntersecting) x.target.classList.add('visible'); });
}, {threshold:.08});
document.querySelectorAll('.reveal').forEach(function(el){ obs.observe(el); });

function enviarCotizacion() {
  var nombre = document.getElementById('cot-nombre').value.trim();
  var tel    = document.getElementById('cot-tel').value.trim();
  var tipo   = document.getElementById('cot-tipo').value;
  var msg    = document.getElementById('cot-msg').value.trim();

  if (!nombre || !tel || !tipo) {
    alert('Por favor completá todos los campos obligatorios.');
    return;
  }

  var texto = 'Hola Nicol%C3%A1s%2C%20quiero%20cotizar%20un%20seguro.%0A%0A';
  texto += 'Nombre%3A%20' + encodeURIComponent(nombre) + '%0A';
  texto += 'Tel%C3%A9fono%3A%20' + encodeURIComponent(tel) + '%0A';
  texto += 'Seguro%3A%20' + encodeURIComponent(tipo);
  if (msg) texto += '%0AMensaje%3A%20' + encodeURIComponent(msg);
  texto += '%0A%0AQuedo%20esperando%20tu%20cotizaci%C3%B3n.%20Gracias.';

  window.open('https://wa.me/5493517315099?text=' + texto, '_blank');
}
</script>
</body>
</html>
